#!/usr/bin/env bash
set -euo pipefail

REPO_SLUG="${LIN_DOS_REPO:-bmja62/lin-dos}"
BRANCH="${LIN_DOS_BRANCH:-main}"
INSTALL_DIR="${LIN_DOS_HOME:-$HOME/.local/share/lin-dos}"
ARCHIVE_URL="https://github.com/${REPO_SLUG}/archive/refs/heads/${BRANCH}.tar.gz"
TMP_DIR="$(mktemp -d)"

cleanup() {
    rm -rf "${TMP_DIR}"
}
trap cleanup EXIT

echo "Downloading LIN-DOS from ${ARCHIVE_URL}"
curl -fsSL "${ARCHIVE_URL}" | tar -xz -C "${TMP_DIR}"

SRC_DIR="${TMP_DIR}/$(basename "${REPO_SLUG}")-${BRANCH}"
SRC_BASE="${SRC_DIR}/src"
if [[ ! -d "${SRC_BASE}" ]]; then
    echo "Failed to locate extracted LIN-DOS source."
    exit 1
fi

mkdir -p "${INSTALL_DIR}"
for dir in cd cls copy date help md rd time tree type ver; do
    rm -rf "${INSTALL_DIR}/${dir}"
    cp -R "${SRC_BASE}/${dir}" "${INSTALL_DIR}/${dir}"
done

for file in command.com lindos.sh; do
    cp "${SRC_BASE}/${file}" "${INSTALL_DIR}/${file}"
done

for file in README.MD readme.md LICENSE license; do
    if [[ -f "${SRC_DIR}/${file}" ]]; then
        cp "${SRC_DIR}/${file}" "${INSTALL_DIR}/${file}"
    fi
done

BASHRC_FILE="${HOME}/.bashrc"
LIN_DOS_MARKER="# LIN-DOS (lindos command)"
INIT_LINE="[[ -f \"${INSTALL_DIR}/lindos.sh\" ]] && source \"${INSTALL_DIR}/lindos.sh\""
if [[ -f "${BASHRC_FILE}" ]] && grep -Fq "${LIN_DOS_MARKER}" "${BASHRC_FILE}"; then
    echo "LIN-DOS is already configured in ${BASHRC_FILE}"
else
    echo "" >> "${BASHRC_FILE}"
    echo "${LIN_DOS_MARKER}" >> "${BASHRC_FILE}"
    echo "${INIT_LINE}" >> "${BASHRC_FILE}"
    echo "Added lindos command to ${BASHRC_FILE}"
fi

echo "LIN-DOS installed at ${INSTALL_DIR}"
echo "Run: source \"${BASHRC_FILE}\"  # then: lindos (load) or lindos update (latest)"
